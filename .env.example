# ============================================================
# 🤖 hAI.OpenCodeHAI - Umgebungsvariablen
# Kopieren: cp .env.example .env
# Dann .env mit echten Werten befüllen – niemals committen!
# ============================================================

# --- AI Provider API Keys ---
# Mindestens einen Key eintragen

OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://9router.example.com/v1

ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=

# --- Modell-Auswahl ---
OPENCODE_MODEL=deepseek/deepseek-chat

# --- GitHub MCP (optional) ---
# Benötigt für GitHub-MCP-Server (Port 3001)
# Token erstellen: https://github.com/settings/tokens
# Benötigte Scopes: repo, read:org
GITHUB_TOKEN=github_pat_...
