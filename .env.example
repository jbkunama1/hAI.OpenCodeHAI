# ============================================================
# 🤖 hAI.OpenCodeHAI - Konfiguration
# cp .env.example .env  →  Werte eintragen  →  fertig!
# ⚠️  NIEMALS die .env-Datei in Git committen!
# ============================================================

# ──────────────────────────────────────────
# 🔑 API-Keys (nur benötigte eintragen)
# ──────────────────────────────────────────

# DeepSeek – großzügiges Free-Tier! ✅
DEEPSEEK_API_KEY=sk-...

# Google Gemini – Free-Tier verfügbar ✅
GOOGLE_API_KEY=AIza...

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter (Zugang zu vielen Modellen, auch Free-Tier) ✅
OPENROUTER_API_KEY=sk-or-...

# ──────────────────────────────────────────
# 🤖 Standard-Modell
# ──────────────────────────────────────────
# Empfehlungen für kostenloses Setup:
#   deepseek/deepseek-chat
#   google/gemini-2.0-flash
#   qwen/qwen-2.5-coder-32b-instruct:free  (via OpenRouter)
OPENCODE_MODEL=deepseek/deepseek-chat

# ──────────────────────────────────────────
# 🌐 Ollama – lokale Modelle (optional)
# ──────────────────────────────────────────
# Ollama läuft auf dem Host:
OLLAMA_HOST=http://host.docker.internal:11434
# Ollama auf anderem Server:
# OLLAMA_HOST=http://192.168.1.100:11434
